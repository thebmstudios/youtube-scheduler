# ============================================
# YouTube Smart Scheduler - Environment Config
# ============================================

# Google OAuth2 Credentials
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# YouTube Channel ID (starts with UC...)
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx

# Server Config
PORT=3000
NODE_ENV=development

# Database path
DB_PATH=./data/scheduler.db

# Notification (optional - for email alerts)
NOTIFY_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Re-analysis interval in hours (default: 24)
REANALYZE_INTERVAL_HOURS=24
